{
  "name": "luobi",
  "version": "1.0.0",
  "description": "落笔 — AI-powered git commit message assistant. Stage your changes, run `lb`, and get a Conventional Commits message in Chinese.",
  "type": "module",
  "bin": {
    "lb": "./dist/index.js",
    "luobi": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
